#!/usr/bin/env node

const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');

const home = os.homedir();
const root = path.join(home, '.config', 'pi', 'catppuccin');
const configPath = path.join(root, 'config.json');
const basePath = path.join(root, 'base.json');
const presetDir = path.join(root, 'presets');
const outputDir = path.join(home, '.pi', 'agent', 'themes');

function readJson(file) {
  return JSON.parse(fs.readFileSync(file, 'utf8'));
}

function isPlainObject(value) {
  return value !== null && typeof value === 'object' && !Array.isArray(value);
}

function merge(base, override) {
  if (!isPlainObject(base) || !isPlainObject(override)) {
    return override;
  }

  const merged = { ...base };
  for (const [key, value] of Object.entries(override)) {
    if (isPlainObject(value) && isPlainObject(merged[key])) {
      merged[key] = merge(merged[key], value);
    } else {
      merged[key] = value;
    }
  }
  return merged;
}

function main() {
  const config = readJson(configPath);
  let theme = readJson(basePath);
  const appliedPresets = [];

  for (const [presetName, enabled] of Object.entries(config.presets || {})) {
    if (!enabled) continue;
    const presetPath = path.join(presetDir, `${presetName}.json`);
    if (!fs.existsSync(presetPath)) {
      throw new Error(`Missing preset file: ${presetPath}`);
    }
    theme = merge(theme, readJson(presetPath));
    appliedPresets.push(presetName);
  }

  if (config.themeOverrides) {
    theme = merge(theme, config.themeOverrides);
  }

  const themeName = config.themeName || 'catppuccin-custom';
  theme.name = themeName;

  fs.mkdirSync(outputDir, { recursive: true });
  const outputPath = path.join(outputDir, `${themeName}.json`);
  fs.writeFileSync(outputPath, `${JSON.stringify(theme, null, 2)}\n`);

  const summary = appliedPresets.length ? appliedPresets.join(', ') : 'none';
  console.log(`Wrote ${outputPath}`);
  console.log(`Applied presets: ${summary}`);
}

main();
